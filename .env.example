# Same Redis your trading engine uses (e.g. npm run publish-test)
REDIS_URL=redis://127.0.0.1:6379

# UI tabs: PC vs Demo Redis (server reads these; not exposed to the browser)
TPM_PC_REDIS_URL=redis://127.0.0.1:6379
TPM_DEMO_REDIS_URL=redis://127.0.0.1:6379

# Comma-separated stream keys (must match KEY_STREAM.* in your app)
STREAM_KEYS=trading:fill-price

# HTTP port for the test UI
PORT=3847

# Recent messages to load when opening the UI (XREVRANGE; does not delete from Redis)
HISTORY_COUNT=20
